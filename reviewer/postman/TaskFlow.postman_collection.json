      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{seed_user_name}}\",\n  \"email\": \"{{seed_user_email}}\",\n  \"password\": \"{{seed_user_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('token', json.token);",
                  "  if (json.token) pm.environment.set('token', json.token);",
                  "  if (json.user && json.user.id) pm.collectionVariables.set('user_id', json.user.id);",
                  "  if (json.user && json.user.id) pm.environment.set('user_id', json.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
