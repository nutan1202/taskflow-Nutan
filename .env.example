# Copy to .env — never commit .env
# PostgreSQL (used by docker-compose and API)
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy / Alembic (async-compatible URL; adjust driver if you switch stack)
DATABASE_URL=postgresql+psycopg://taskflow:taskflow@db:5432/taskflow

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Security (generate a long random string for production)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# bcrypt
BCRYPT_ROUNDS=12
