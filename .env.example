# Copy to .env (repo root) for Docker Compose
# This file is for infra + API runtime inside containers.

APP_NAME=TaskFlow API
ENVIRONMENT=development
DEBUG=true

# PostgreSQL container settings
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PUBLISH_PORT=5432

# API runtime
API_HOST=0.0.0.0
API_PORT=8000
API_PUBLISH_PORT=8000
LOG_LEVEL=INFO

# SQLAlchemy / Alembic
DATABASE_URL=postgresql+psycopg://taskflow:taskflow@db:5432/taskflow

# Security
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
BCRYPT_ROUNDS=12

# Seed user
SEED_USER_EMAIL=test@example.com
SEED_USER_PASSWORD=password123
SEED_USER_NAME=Test User
