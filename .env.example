# Optional override file for Docker Compose.
# `docker compose up --build` works without this file.
# Create `.env` from this template only when you want custom values.
#
# Note: Compose reads TASKFLOW_* host variables and maps them to container
# runtime variables expected by the app.

TASKFLOW_APP_NAME=TaskFlow API
TASKFLOW_ENVIRONMENT=development
TASKFLOW_DEBUG=true

# PostgreSQL settings
TASKFLOW_POSTGRES_USER=taskflow
TASKFLOW_POSTGRES_PASSWORD=taskflow
TASKFLOW_POSTGRES_DB=taskflow
TASKFLOW_POSTGRES_HOST=db
TASKFLOW_POSTGRES_PORT=5432
TASKFLOW_POSTGRES_PUBLISH_PORT=5432

# API runtime
TASKFLOW_API_HOST=0.0.0.0
TASKFLOW_API_PORT=8000
TASKFLOW_API_PUBLISH_PORT=8000
TASKFLOW_LOG_LEVEL=INFO

# SQLAlchemy / Alembic
TASKFLOW_DATABASE_URL=postgresql+psycopg://taskflow:taskflow@db:5432/taskflow

# Security
TASKFLOW_JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
TASKFLOW_JWT_ALGORITHM=HS256
TASKFLOW_BCRYPT_ROUNDS=12

# Seed user
TASKFLOW_SEED_USER_EMAIL=test@example.com
TASKFLOW_SEED_USER_PASSWORD=password123
TASKFLOW_SEED_USER_NAME=Test User

# Startup behavior
TASKFLOW_RUN_DB_SEED=true
